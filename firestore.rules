rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notes
    // Document ID: {noteId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - content: string (required)
    //   - tags: list (optional)
    //   - category: string (optional)
    //   - createdAt: number (optional)
    //   - updatedAt: number (required)
    //   - syncStatus: string (optional)
    //   - version: number (optional)
    //   - isPinned: bool (optional)
    //   - userId: string (required) - Owner of the note
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidNote(data) {
      return data.id is string &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.userId == request.auth.uid &&
             data.updatedAt is number;
    }

    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNote(request.resource.data);
      allow update: if isDocOwner() && isValidNote(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
